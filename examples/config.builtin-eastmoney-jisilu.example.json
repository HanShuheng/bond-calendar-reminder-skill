{
  "_comment": "内置示例适配器配置：东方财富日历为主，集思录日历兜底/交叉检查，东方财富 push2 用于上市日行情检查。",
  "calendar_strategy": {
    "type": "builtin",
    "adapters": [
      {
        "type": "eastmoney",
        "_comment": "主日历示例适配器。字段里包含申购日、中签结果公布日和上市日。",
        "api_url": "https://datacenter-web.eastmoney.com/api/data/v1/get",
        "params": {
          "reportName": "RPT_BOND_CB_LIST",
          "columns": "ALL",
          "source": "WEB",
          "client": "WEB",
          "pageNumber": "1",
          "pageSize": "2000",
          "sortColumns": "PUBLIC_START_DATE,SECURITY_CODE",
          "sortTypes": "-1,1"
        },
        "headers": {
          "Referer": "https://data.eastmoney.com/xg/xg/?mkt=kzz"
        }
      },
      {
        "type": "jisilu",
        "_comment": "兜底/交叉检查日历示例适配器。使用前请自行确认授权和访问规则。",
        "calendar_url": "https://www.jisilu.cn/data/calendar/get_calendar_data/?qtype=CNV",
        "base_url": "https://www.jisilu.cn",
        "detail_url_template": "https://www.jisilu.cn/data/convert_bond_detail/{code}",
        "headers": {
          "Referer": "https://www.jisilu.cn/data/calendar/"
        }
      }
    ]
  },
  "quote_strategy": {
    "_comment": "内置行情示例适配器，用于上市日 30% 涨幅检查。",
    "type": "eastmoney_push2",
    "api_url": "https://push2.eastmoney.com/api/qt/stock/get",
    "params": {
      "secid": "{eastmoney_secid}",
      "fields": "f57,f58,f43,f60,f169,f170,f86"
    },
    "headers": {
      "Referer": "https://data.eastmoney.com/kzz/"
    }
  },
  "trade_calendar_strategy": {
    "_comment": "内置交易日历示例适配器，用于 is-trade-day 命令判断中国 A 股交易日。",
    "type": "baostock"
  },
  "auto_setup_schedule": {
    "enabled": true,
    "daily_time": "07:00",
    "tracking_time": "07:05",
    "limit_up_time": "14:50"
  },
  "subscribe_reminder_schedule": [
    {
      "time": "10:00",
      "label": "10:00 申购提醒"
    },
    {
      "time": "12:30",
      "label": "12:30 申购提醒"
    }
  ],
  "winning_reminder_schedule": [
    {
      "time": "10:30",
      "label": "10:30 中签结果公布提醒"
    },
    {
      "time": "13:00",
      "label": "13:00 中签结果公布提醒"
    }
  ],
  "listing_reminder_schedule": [
    {
      "days_offset": -1,
      "time": "12:00",
      "label": "上市前一天提醒"
    },
    {
      "days_offset": 0,
      "time": "09:25",
      "label": "上市当天 09:25，开盘前提醒"
    },
    {
      "days_offset": 0,
      "time": "13:30",
      "label": "上市当天 13:30"
    }
  ],
  "listing_limit_up_reminder": {
    "enabled": true,
    "check_time": "14:50",
    "reminder_time": "14:55",
    "threshold_percent": 30,
    "label": "上市当天 30% 涨停 14:55 提醒"
  }
}
